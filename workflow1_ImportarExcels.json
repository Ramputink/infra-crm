    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH ins AS (\n  INSERT INTO public.import_batches (filename, file_hash, status, imported_by)\n  VALUES ($1, $2, $3, $4)\n  ON CONFLICT (file_hash) DO UPDATE\n    SET filename = EXCLUDED.filename\n  RETURNING id\n)\nSELECT id FROM ins\nUNION ALL\nSELECT id FROM public.import_batches WHERE file_hash = $2\nLIMIT 1;",
        "options": {
          "queryReplacement": "$('On form submission').first().binary.excel_file.fileName,   $('Crypto').first().json.fileHash,   'processing',   'n8n_form'"
        }
