    {
      "parameters": {
        "jsCode": "const formItem = $('On form submission').first();\n\nreturn [{\n  json: $input.first().json,     // mantiene tu JSON actual (batch id, etc.)\n  binary: formItem.binary,       // reinyecta el excel_file\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        16
      ],
      "id": "318b582b-6dc4-4c43-8ddb-8a18e3f1f783",
      "name": "Reinyectar Binario"
    },
    {
      "parameters": {
        "jsCode": "// ============================================================\n// NODO 7: Normalizar Leads (con import_batch_id REAL)\n// ============================================================\n\nconst items = $input.all();\n\n// ⚠️ Debe existir el nodo que inserta en import_batches y devuelve el id\n// Cambia 'Registrar batch' por el nombre EXACTO de tu nodo en n8n.\nconst batchNodeName = 'Registrar batch';\n\n// Intentar obtener el batchId del nodo de registro\nconst batchId = $(batchNodeName).first()?.json?.id;\n\n// Si no existe, mejor fallar aquí que insertar con null y romper import_rows\nif (!batchId) {\n  throw new Error(\n    `No se pudo obtener batchId desde el nodo \"${batchNodeName}\". ` +\n    `Asegúrate de que el nodo hace INSERT en import_batches y tiene \"Return id\" activado.`\n  );\n}\n\nreturn items.map((item, index) => {\n  const d = item.json;\n\n  // === NOMBRE ===\n  const rawName = (d['Contacto'] || '').trim();\n  const parts = rawName.split(/\\s+/);\n\n  const firstNameParts = [];\n  const lastNameParts = [];\n\n  for (const part of parts) {\n    // Palabras como \"DE\", \"LA\", \"DEL\" van con el grupo actual\n    if (part.length <= 2 && part === part.toUpperCase()) {\n      if (lastNameParts.length > 0) lastNameParts.push(part.toLowerCase());\n      else firstNameParts.push(part);\n    } else if (part === part.toUpperCase() && part.length > 2) {\n      lastNameParts.push(part);\n    } else {\n      firstNameParts.push(part);\n    }\n  }\n\n  const capitalize = (str) => str.charAt(0).toUpperCase() + str.slice(1).toLowerCase();\n\n  const firstName = firstNameParts\n    .map(w => (w.length <= 2 ? w.toLowerCase() : capitalize(w)))\n    .join(' ') || rawName;\n\n  const lastName = lastNameParts\n    .map(w => (w.length <= 2 ? w.toLowerCase() : capitalize(w)))\n    .join(' ');\n\n  const fullName = `${firstName} ${lastName}`.trim();\n\n  // === EMAIL ===\n  const rawEmail = (d['Opportunity : Contact : Email'] || '').trim().toLowerCase();\n  const emailValid = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(rawEmail);\n\n  // === TELÉFONO ===\n  let phone = (d['Opportunity : Contacto : Phone'] || '').toString().trim();\n  phone = phone.replace(/\\.0$/, '');\n  phone = phone.replace(/[^\\d+]/g, '');\n  if (phone && !phone.startsWith('+')) phone = '+' + phone;\n\n  // === CATEGORÍA ===\n  const tipoProducto = (d['Tipo de Producto'] || '').toUpperCase().trim();\n  let category = 'sin_categorizar';\n\n  if (tipoProducto === 'GRADO') {\n    category = 'grado';\n  } else if (tipoProducto === 'CFGS' || tipoProducto === 'CURSO CORTO' || tipoProducto === 'MENCION') {\n    category = 'curso';\n  } else if (tipoProducto === 'POSTGRADO' || tipoProducto.includes('MASTER') || tipoProducto.includes('MÁSTER')) {\n    category = 'master';\n  }\n\n  // === SEDE / CAMPUS ===\n  const opportunityName = d['Opportunity Name'] || '';\n  let campus = 'otro';\n  if (opportunityName.includes('Andalucía') || opportunityName.includes('Andalucia')) {\n    campus = 'andalucia';\n  } else if (opportunityName.includes('Villaviciosa') || opportunityName.includes('Odón')) {\n    campus = 'villaviciosa';\n  }\n\n  // === FECHA INSCRIPCIÓN ===\n  let fechaInscripcion = null;\n  const rawFecha = d['Opportunity : Synced Quote : Fecha inscripción'];\n\n  if (rawFecha) {\n    if (typeof rawFecha === 'number') {\n      const jsDate = new Date((rawFecha - 25569) * 86400 * 1000);\n      fechaInscripcion = jsDate.toISOString().split('T')[0];\n    } else if (typeof rawFecha === 'string') {\n      const parsed = new Date(rawFecha);\n      if (!Number.isNaN(parsed.getTime())) {\n        fechaInscripcion = parsed.toISOString().split('T')[0];\n      }\n    } else if (rawFecha instanceof Date) {\n      fechaInscripcion = rawFecha.toISOString().split('T')[0];\n    }\n  }\n\n  // === COLUMNAS OPCIONALES ===\n  const source = d['Source'] ? d['Source'].toString().trim() : null;\n  const asesorConsolidacion = d['Asesor Consolidación'] ? d['Asesor Consolidación'].toString().trim() : null;\n\n  const tipoMatricula = d['Opportunity : Synced Quote : TipoMatricula']\n    ? d['Opportunity : Synced Quote : TipoMatricula'].toString().trim()\n    : null;\n\n  return {\n    json: {\n      // Datos normalizados\n      full_name: fullName,\n      first_name: firstName,\n      last_name: lastName,\n      email: emailValid ? rawEmail : null,\n      email_valid: emailValid,\n      phone: phone || null,\n      country: (d['País de Nacimiento'] || '').trim(),\n      language: (d['Opportunity : Contact : Contact Language'] || 'Español').trim(),\n      category,\n      campus,\n\n      // Datos académicos\n      tipo_producto: tipoProducto || null,\n      codigo_titulo: d['Código Título'] ? d['Código Título'].toString().trim() : null,\n      facultad: (d['Facultad'] || '').trim() || null,\n      titling: (d['Titling'] || '').trim() || null,\n      stage: (d['Stage'] || '').trim() || null,\n\n      // Datos comerciales\n      assessor: (d['Assessor name'] || '').trim() || null,\n      asesor_consolidacion: asesorConsolidacion,\n      source,\n      tipo_matricula: tipoMatricula,\n      application_number: d['Application number'] || null,\n      expediente: d['Nº de Expediente'] || null,\n      fecha_inscripcion: fechaInscripcion,\n\n      // Metadatos de importación\n      import_batch_id: batchId,\n      row_number: index + 1,\n\n      // ✅ Guardar como objeto para JSONB (mejor que string)\n      raw_data: d\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1408,
        16
      ],
      "id": "cd0b589c-211f-4c77-8912-82d92d1fd2d8",
      "name": "Normalizar datos"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const d = item.json;\n  const errors = [];\n\n  if (!d.email) errors.push('email_missing_or_invalid');\n  if (!d.full_name || d.full_name.length < 2) errors.push('name_missing');\n\n  results.push({\n    json: {\n      ...d,\n      validation_errors: errors,\n      status: errors.length > 0 ? 'error' : 'ok'\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1616,
        16
      ],
      "id": "714c8df7-332e-40eb-a079-14fb2e950b79",
      "name": "Filtrar Invalidos"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().filter(item => {\n  const email = item.json.email;\n  return typeof email === 'string' && email.trim() !== '';\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1824,
        16
      ],
      "id": "51762c08-4199-422c-a019-ffc199cbc7e1",
      "name": "Limpiar Mails Vacios"
    },
